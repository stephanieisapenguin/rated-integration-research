# Backend environment variables.
# Copy to .env for local dev; set these in your host's dashboard for production
# (Render → Environment, Railway → Variables, Fly → secrets).

# Port the backend listens on. Render injects $PORT automatically; locally we
# default to 8000 to match the frontend's VITE_API_BASE_URL.
PORT=8000

# Comma-separated list of origins allowed by CORS.
# Local dev: http://localhost:5173 (Vite default)
# Production: your Netlify URL, e.g. https://rated.netlify.app
ALLOWED_ORIGINS=http://localhost:5173

# Postgres connection string (when we move off the in-memory store).
# Netlify DB → copy DATABASE_URL from Netlify dashboard → Extensions → Neon.
# Leave unset to keep using the in-memory App() store.
DATABASE_URL=

# Google OAuth client ID — used to verify id_token from the frontend's Google
# sign-in. Stub auth currently accepts any "sub|name|email" string; once this is
# set, /auth/login will validate real Google JWTs.
GOOGLE_CLIENT_ID=
