# Frontend (Vite) environment variables.
# Copy to .env.local for local dev. Vite only exposes vars prefixed with VITE_.
# In production, set these in Netlify → Site settings → Environment variables.

# Backend API base URL.
# Local dev:  http://localhost:8000
# Production: https://<your-backend-host>   (Render / Railway / Fly)
VITE_API_BASE_URL=http://localhost:8000

# TMDB v3 API key from https://www.themoviedb.org/settings/api
# Optional — when unset, the app falls back to a small hardcoded movie catalog.
VITE_TMDB_API_KEY=
